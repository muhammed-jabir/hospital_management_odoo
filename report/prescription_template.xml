<?xml version="1.0" encoding="UTF-8"?>
<odoo>

<template id="report_prescription_document">
    <t t-call="web.html_container">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <div class="page">

                    <h2 class="text-center">Caretera Hospital</h2>
                    <h4 class="text-center">Medical Prescription</h4>

                    <div class="row mt-4">
                        <div class="col-6">
                            <strong>Prescription No:</strong>
                            <span t-esc="o.name"/>
                        </div>
                        <div class="col-6 text-end">
                            <strong>Date:</strong>
                            <span t-esc="o.date"/>
                        </div>
                    </div>

                    <hr/>

                    <div class="row">
                        <div class="col-6">
                            <strong>Patient:</strong>
                            <span t-esc="o.patient_id.name"/>
                        </div>
                        <div class="col-6">
                            <strong>Doctor:</strong>
                            <span t-esc="o.doctor_id.name"/>
                        </div>
                    </div>

                    <div class="mt-3">
                        <strong>Diagnosis:</strong>
                        <p t-esc="o.diagnosis"/>
                    </div>

                    <table class="table table-bordered mt-4">
                        <thead>
                            <tr>
                                <th>Medicine</th>
                                <th>Dosage</th>
                                <th>Frequency</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.line_ids" t-as="l">
                                <td><span t-esc="l.medicine_name"/></td>
                                <td><span t-esc="l.dosage"/></td>
                                <td><span t-esc="l.frequency"/></td>
                                <td><span t-esc="l.duration"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="mt-3">
                        <strong>Advice:</strong>
                        <p t-esc="o.advice"/>
                    </div>

                    <div class="mt-5 text-end">
                        <strong>Doctor Signature</strong>
                        <br/><br/>
                        <span t-esc="o.doctor_id.name"/>
                    </div>

                </div>
            </t>
        </t>
    </t>
</template>

</odoo>