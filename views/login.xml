<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <template id="login_page" name="Hospital Login">

        <t t-call="website.layout">
            <link rel="stylesheet" href="/hospital_management/static/src/css/login.css"/>

            <section class="login-page">

                <div class="row justify-content-center ">

                    <div class="col-lg-5">

                        <div class="login-card">

                            <h2 class="text-center mb-4">
                                Caretera Hospital
                            </h2>

                            <h4 class="text-center">
                                Welcome Back
                            </h4>

                            <!-- THIS WAS MISSING: login_submit() already sends
                                 back {'error': 'invalid login or password'} on
                                 failure, but nothing here ever displayed it -->
                            <div t-if="error" class="alert alert-danger mt-3" t-esc="error"/>

                            <form action="/login/submit" method="post" class="mt-3">

                                <input type="hidden"
                                       name="csrf_token"
                                       t-att-value="request.csrf_token()"/>

                                <div class="mb-3">
                                    <input type="text"
                                           name="login"
                                           class="form-control"
                                           placeholder="Email"
                                           required="required"/>
                                </div>

                                <div class="mb-3">
                                    <input type="password"
                                           name="password"
                                           class="form-control"
                                           placeholder="Password"
                                           required="required"/>
                                </div>

                                <button type="submit" class="login-btn">
                                    Login
                                </button>

                            </form>

                            <div class="text-center mt-3">
                                Don't have an account?
                                <a href="/register">
                                    Register
                                </a>
                            </div>

                        </div>

                    </div>

                </div>

            </section>

        </t>

    </template>

</odoo>